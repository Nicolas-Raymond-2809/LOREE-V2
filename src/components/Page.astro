---
interface Props {
  pageNumber: number;
  totalPages: number;
}

const { pageNumber, totalPages } = Astro.props;

// Computations for dynamic z-index based on page number
const defaultZ = totalPages - pageNumber + 10;
const flippedZ = pageNumber;

// ID des états globaux (Boutons Radios définis dans Book.astro)
const forwardRadioId = `radio-page-${pageNumber}`;
const backwardRadioId = `radio-page-${pageNumber - 1}`;
---

<div class="page-container" id={`page-container-${pageNumber}`}>
  <!-- Recto (Front of the page, visible when unflipped on the right side) -->
  <div class="side front">
    <slot name="bg-front" />
    <!-- Navigation Supérieure (Sommaire en haut) -->
    <div class="absolute bottom-6 left-0 w-full flex justify-center z-20 pointer-events-none">
      <label for="sommaire-toggle" class="sommaire-btn" tabindex="0" role="button" aria-label="Ouvrir le sommaire">
        Sommaire
      </label>
    </div>

    <div class="content">
      <slot name="front" />
    </div>
    
    <!-- Navigation Inférieure (Bouton Suivant uniquement à droite) -->
    <div class="nav-front absolute bottom-6 right-8 z-20 pointer-events-none">
      {pageNumber < totalPages && (
        <label for={forwardRadioId} class="turn-btn forward" tabindex="0" role="button" aria-label="Page suivante">
          <span class="btn-text">Suivant &rarr;</span>
        </label>
      )}
    </div>
  </div>

  <!-- Verso (Back of the page, visible when flipped on the left side) -->
  <div class="side back">
    <slot name="bg-back" />
    
    <!-- Navigation Supérieure (Sommaire en haut) -->
    <div class="absolute bottom-6 left-0 w-full flex justify-center z-20 pointer-events-none">
      <label for="sommaire-toggle" class="sommaire-btn" tabindex="0" role="button" aria-label="Ouvrir le sommaire">
        Sommaire
      </label>
    </div>

    <div class="content">
      <slot name="back" />
    </div>
    
    <!-- Navigation Inférieure (Bouton Précédent uniquement à gauche du livre = bord droit local) -->
    <div class="nav-back absolute bottom-6 left-8 z-20 pointer-events-none">
      <label for={backwardRadioId} class="turn-btn backward" tabindex="0" role="button" aria-label="Page précédente">
        <span class="btn-text">&larr; Précédent</span>
      </label>
    </div>
  </div>
</div>

<style define:vars={{ defaultZ, flippedZ }}>
  .page-container {
    position: absolute;
    top: 0;
    left: 50%; /* Position on the right half of the book */
    width: 50%;
    height: 100%;
    transform-origin: left center;
    transform-style: preserve-3d;
    z-index: var(--defaultZ);
    /* Transformation gérée par Book.astro, transition gérée ici */
    transition: transform 0.6s cubic-bezier(0.8, 0.045, 0.355, 1), z-index 0s 0.3s;
  }

  .side {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    background-color: var(--page-bg);
    border: 1px solid var(--page-border);
    box-sizing: border-box;
    /* Box shadow to simulate page depth slightly */
    box-shadow: inset 0 0 15px rgba(0,0,0,0.02), 2px 2px 5px var(--page-shadow);
    display: flex;
    flex-direction: column;
  }

  /* The back is rotated 180deg natively so it faces opposite */
  .side.back {
    transform: rotateY(180deg);
    /* Shadow on the opposite side to give depth when flipped */
    box-shadow: inset 0 0 15px rgba(0,0,0,0.02), -2px 2px 5px var(--page-shadow);
  }

  .content {
    flex-grow: 1;
    overflow-y: auto;
    padding: 2rem;
    padding-bottom: 5rem;
  }

  /* Interaction Buttons (Labels hooked to checkboxes) */
  .turn-btn {
    pointer-events: auto; /* Permet de cliquer malgré le nav-wrapper none */
    cursor: pointer;
    text-align: center;
    padding: 1rem 1.8rem;
    font-size: 1.1rem;
    font-style: italic;
    color: #666;
    transition: color 0.3s, background-color 0.3s;
    user-select: none;
    display: inline-block;
    border-radius: 8px;
    background-color: rgba(248, 247, 245, 0.4);
    backdrop-filter: blur(2px);
  }

  /* Règle par défaut ciblée : Par défaut, la face arrière (back) est cachée derrière et à l'envers. */
  /* On désactive strictement les balises d'interaction matérielle connues pour libérer les clics. */
  .side.back a,
  .side.back button,
  .side.back label {
    pointer-events: none;
  }

  .turn-btn:hover {
    color: #000;
    background-color: rgba(248, 247, 245, 0.9);
  }

  .turn-btn:focus-visible {
    outline: 2px solid #333;
    outline-offset: 2px;
  }

  /* Hide scrollbar for cleaner book feel */
  .content::-webkit-scrollbar {
    width: 4px;
  }
  .content::-webkit-scrollbar-thumb {
    background: rgba(0,0,0,0.1);
    border-radius: 4px;
  }

  /* Bouton Sommaire Centré */
  .sommaire-btn {
    pointer-events: auto; /* Permet de cliquer malgré le nav-wrapper none */
    cursor: pointer;
    text-align: center;
    padding: 1rem 1.8rem;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a793ac; /* accent */
    transition: color 0.3s, background-color 0.3s;
    user-select: none;
    display: inline-block;
    border-radius: 8px;
    background-color: rgba(248, 247, 245, 0.4);
    backdrop-filter: blur(2px);
  }

  .sommaire-btn:hover {
    color: #79B6D8; /* primary hover */
    background-color: rgba(248, 247, 245, 0.9);
  }

  .sommaire-btn:focus-visible {
    outline: 2px solid #333;
    outline-offset: 2px;
  }
</style>
